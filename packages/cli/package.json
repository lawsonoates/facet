{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@lawsonoates/facet-cli",
	"version": "0.1.0",
	"description": "CLI for running, prompting, and serving Facet agent apps.",
	"author": "Lawson Oates (https://github.com/lawsonoates)",
	"license": "MIT",
	"homepage": "https://github.com/lawsonoates/facet#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lawsonoates/facet.git",
		"directory": "packages/cli"
	},
	"keywords": ["ai", "agent", "cli"],
	"type": "module",
	"bin": {
		"facet": "./dist/cli.mjs"
	},
	"exports": {
		"./cli": {
			"import": "./dist/cli.mjs",
			"types": "./dist/cli.d.mts"
		}
	},
	"files": ["dist"],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsdown",
		"prepublishOnly": "bun run build",
		"typecheck": "tsgo -b --noEmit"
	},
	"dependencies": {
		"@lawsonoates/facet-agent": "workspace:*"
	},
	"devDependencies": {
		"@tsconfig/bun": "catalog:",
		"@types/bun": "catalog:",
		"@typescript/native-preview": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:"
	}
}
