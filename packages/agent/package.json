{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@facet/agent",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/agent.ts",
		"./bot": "./src/bot.ts",
		"./tui": "./src/tui.ts"
	},
	"scripts": {
		"typecheck": "tsgo -b --noEmit"
	},
	"dependencies": {
		"@facet/tui": "workspace:*"
	},
	"peerDependencies": {
		"ai": ">=5.0.0",
		"chat": ">=0.0.0"
	},
	"peerDependenciesMeta": {
		"ai": {
			"optional": true
		},
		"chat": {
			"optional": true
		}
	},
	"devDependencies": {
		"@tsconfig/bun": "catalog:",
		"@types/bun": "catalog:",
		"@typescript/native-preview": "catalog:",
		"ai": "catalog:",
		"chat": "catalog:",
		"typescript": "catalog:"
	}
}
