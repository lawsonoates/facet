{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@lawsonoates/facet-agent",
	"version": "0.1.0",
	"description": "App contract, stable tool IDs, toolset helper, TUI surface, and bot bridge for Facet agents.",
	"author": "Lawson Oates (https://github.com/lawsonoates)",
	"license": "MIT",
	"homepage": "https://github.com/lawsonoates/facet#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lawsonoates/facet.git",
		"directory": "packages/agent"
	},
	"keywords": ["ai", "agent", "ai-sdk"],
	"type": "module",
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		},
		"./bot": {
			"import": "./dist/bot.mjs",
			"types": "./dist/bot.d.mts"
		},
		"./tui": {
			"import": "./dist/tui.mjs",
			"types": "./dist/tui.d.mts"
		}
	},
	"files": ["dist"],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsdown",
		"prepublishOnly": "bun run build",
		"typecheck": "tsgo -b --noEmit"
	},
	"dependencies": {
		"@lawsonoates/facet-tui": "workspace:*"
	},
	"peerDependencies": {
		"ai": ">=5.0.0",
		"chat": ">=0.0.0"
	},
	"peerDependenciesMeta": {
		"ai": {
			"optional": true
		},
		"chat": {
			"optional": true
		}
	},
	"devDependencies": {
		"@tsconfig/bun": "catalog:",
		"@types/bun": "catalog:",
		"@typescript/native-preview": "catalog:",
		"ai": "catalog:",
		"chat": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:"
	}
}
