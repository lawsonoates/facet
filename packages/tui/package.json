{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@lawsonoates/facet-tui",
	"version": "0.1.0",
	"description": "OpenTUI terminal UI surface and stream rendering helpers for Facet agents.",
	"author": "Lawson Oates (https://github.com/lawsonoates)",
	"license": "MIT",
	"homepage": "https://github.com/lawsonoates/facet#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lawsonoates/facet.git",
		"directory": "packages/tui"
	},
	"keywords": ["ai", "agent", "tui", "opentui"],
	"type": "module",
	"exports": {
		"./prompt": {
			"import": "./dist/prompt.mjs",
			"types": "./dist/prompt.d.mts"
		},
		"./stream": {
			"import": "./dist/stream.mjs",
			"types": "./dist/stream.d.mts"
		},
		"./tui": {
			"import": "./dist/tui.mjs",
			"types": "./dist/tui.d.mts"
		},
		"./types": {
			"import": "./dist/types.mjs",
			"types": "./dist/types.d.mts"
		}
	},
	"files": ["dist"],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsdown",
		"prepublishOnly": "bun run build",
		"typecheck": "tsgo -b --noEmit"
	},
	"dependencies": {
		"@opentui/core": "^0.2.15",
		"@opentui/react": "^0.2.15",
		"ai": "catalog:",
		"react": "^19.1.0"
	},
	"devDependencies": {
		"@tsconfig/bun": "catalog:",
		"@types/bun": "catalog:",
		"@types/react": "^19.1.8",
		"@typescript/native-preview": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:"
	}
}
